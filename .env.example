# ==========================================================================
# RetroDash: Environment Variables Template
# ==========================================================================

# Copia este archivo como ".env.local" y rellena con tu API Key real de Gemini.
# Consigue una key gratuita en: https://aistudio.google.com/
VITE_GEMINI_API_KEY=tu_api_key_de_gemini_aqui

# Tu VAPID Key pública de Firebase Cloud Messaging para notificaciones push web
# Generala en la consola de Firebase -> Configuración del proyecto -> Cloud Messaging -> Configuración web -> Certificados Push Web
VITE_FIREBASE_VAPID_KEY=tu_vapid_key_publica_de_firebase_aqui

